# 前端生产镜像：docker build -f docker/Dockerfile.ui .
# syntax=docker/dockerfile:1

FROM node:20-bookworm-slim AS build
WORKDIR /app

COPY star-pivot-ui/package.json star-pivot-ui/package-lock.json ./
RUN npm ci --legacy-peer-deps --ignore-scripts

COPY star-pivot-ui/ .
# Vite 8（rolldown）要求 manualChunks 为函数；项目当前为对象写法，Docker 构建锁定 Vite 7
RUN npm install vite@7.3.6 --save-dev --legacy-peer-deps --ignore-scripts
RUN npm run build

FROM nginx:1.27-alpine
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
