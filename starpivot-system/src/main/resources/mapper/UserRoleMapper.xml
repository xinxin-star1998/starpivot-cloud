<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.org.starpivot.system.mapper.UserRoleMapper">

    <!--
      批量插入用户与角色关联关系
      说明：使用单条 INSERT 多组 VALUES 的方式，一次性写入多条记录，提升插入性能
    -->
    <insert id="insertBatchUserRoles">
        INSERT INTO sys_user_role (user_id, role_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId})
        </foreach>
    </insert>
    <delete id="deleteByRoleIdAndUserId">
        DELETE FROM sys_user_role
            WHERE role_id = #{roleId} AND user_id = #{userId}
    </delete>
    <select id="getRoleIdsByUserId" resultType="java.lang.Long">
        SELECT role_id
        FROM sys_user_role
        WHERE user_id = #{userId}
    </select>

</mapper>


