# 【生产】环境变量

# 应用版本号
VITE_VERSION = 3.0.1

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 地址前缀（生产环境使用带版本的路径，与后端 server.servlet.context-path=/api/v1 对应）
# Nginx 需配置 location /api/v1/ 反向代理到后端
VITE_API_URL = /api/v1
# Delete console
VITE_DROP_CONSOLE = true

# 性能监控上报开关（true/false），生产环境可按需开启
VITE_PERF_REPORT = false
# 性能监控上报地址（POST JSON）
VITE_PERF_REPORT_URL =
# 是否仅上报异常指标
VITE_PERF_ONLY_ABNORMAL = false