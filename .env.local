# 本地开发参考（mvn spring-boot:run / pnpm dev）
# 一般无需 export，application.yml 与 Nacos 默认值已指向 Docker 映射端口

NACOS_SERVER=127.0.0.1:8848
DB_URL=jdbc:mysql://127.0.0.1:3307/star_pivot?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MALL_DB_URL=jdbc:mysql://127.0.0.1:3307/star_pivot_mall?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=root
RABBITMQ_HOST=127.0.0.1
MQ_ENABLED=false

JWT_SECRET=dev-local-jwt-secret-must-be-at-least-32-chars
INTERNAL_SERVICE_TOKEN=dev-internal-token
