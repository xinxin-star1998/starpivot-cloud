<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.org.starpivot.monitor.mapper.MonitorDeptMapper">

    <select id="selectByDeptIds" resultType="cn.org.starpivot.monitor.domain.entity.MonitorDept">
        SELECT dept_id AS deptId, dept_name AS deptName
        FROM sys_dept
        WHERE dept_id IN
        <foreach collection="deptIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND del_flag = '0'
    </select>

    <select id="selectByDeptId" resultType="cn.org.starpivot.monitor.domain.entity.MonitorDept">
        SELECT dept_id AS deptId, dept_name AS deptName
        FROM sys_dept
        WHERE dept_id = #{deptId}
          AND del_flag = '0'
    </select>

</mapper>
