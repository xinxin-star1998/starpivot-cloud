package ${entityPackage};

#foreach ($import in $importList)
import ${import};
#end
import com.baomidou.mybatisplus.annotation.IdType;
import com.baomidou.mybatisplus.annotation.TableId;
import com.baomidou.mybatisplus.annotation.TableName;
import lombok.Data;
#if($table.tree)
import cn.org.starpivot.common.domain.TreeEntity;
#elseif($table.hasBaseEntityColumns())
import cn.org.starpivot.common.entity.BaseEntity;
#end

#if($table.sub)
import ${entityPackage}.${subClassName};
#end

/**
 * ${functionName}实体类 ${tableName}
 * 
 * @author ${author}
 * @since ${datetime}
 */
@Data
@TableName("${tableName}" )
#if($table.tree)
public class ${ClassName} extends TreeEntity
#elseif(($table.crud || $table.sub) && $table.hasBaseEntityColumns())
public class ${ClassName} extends BaseEntity
#else
public class ${ClassName}
#end
{
    private static final long serialVersionUID = 1L;

#foreach ($column in $columns)
#if(!$table.isSuperColumn($column.javaField))
    /**
     * $column.columnComment
     */
    #if($column.pk)
    @TableId(value = "$column.columnName" , type = IdType.AUTO)
    #end
#if($column.javaType == 'LocalDateTime' || $column.javaType == 'Date' || $column.javaField == 'createTime' || $column.javaField == 'updateTime')
    @JsonFormat(pattern = "yyyy-MM-dd HH:mm:ss", timezone = "GMT+8")
    private LocalDateTime $column.javaField;
#else
    private $column.javaType $column.javaField;
#end

#end
#end
#if($table.sub)
    /**
     * ${subTable.functionName}信息列表
     */
    private List<${subClassName}> ${subclassName}List;

#end
}

