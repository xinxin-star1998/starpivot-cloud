<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.org.starpivot.mall.pms.mapper.PmsAttrGroupMapper">
    
    <resultMap type="cn.org.starpivot.mall.pms.entity.PmsAttrGroup" id="PmsAttrGroupResult">
        <result property="attrGroupId"    column="attr_group_id"    />
        <result property="attrGroupName"    column="attr_group_name"    />
        <result property="sort"    column="sort"    />
        <result property="descript"    column="descript"    />
        <result property="icon"    column="icon"    />
        <result property="catelogId"    column="catelog_id"    />
    </resultMap>

    <sql id="selectPmsAttrGroupVo">
        select attr_group_id, attr_group_name, sort, descript, icon, catelog_id from pms_attr_group
    </sql>
    <select id="selectPageList" parameterType="cn.org.starpivot.mall.pms.domain.dto.PmsAttrGroupQueryDTO" resultMap="PmsAttrGroupResult">
        <include refid="selectPmsAttrGroupVo"/>
        <where>
            <if test="queryDTO.attrGroupName != null  and queryDTO.attrGroupName != ''">
                and attr_group_name like concat('%',#{queryDTO.attrGroupName}, '%')
            </if>
            <if test="queryDTO.sort != null ">
                and sort = #{queryDTO.sort}
            </if>
            <if test="queryDTO.descript != null  and queryDTO.descript != ''">
                and descript = #{queryDTO.descript}
            </if>
            <if test="queryDTO.icon != null  and queryDTO.icon != ''">
                and icon = #{queryDTO.icon}
            </if>
            <if test="queryDTO.catelogId != null ">
                and catelog_id = #{queryDTO.catelogId}
            </if>
        </where>
    </select>

    <select id="selectListByQuery" parameterType="cn.org.starpivot.mall.pms.domain.dto.PmsAttrGroupQueryDTO" resultMap="PmsAttrGroupResult">
        <include refid="selectPmsAttrGroupVo"/>
        <where>
            <if test="queryDTO.attrGroupName != null  and queryDTO.attrGroupName != ''">
                and attr_group_name like concat('%',#{queryDTO.attrGroupName}, '%')
            </if>
            <if test="queryDTO.sort != null ">
                and sort = #{queryDTO.sort}
            </if>
            <if test="queryDTO.descript != null  and queryDTO.descript != ''">
                and descript = #{queryDTO.descript}
            </if>
            <if test="queryDTO.icon != null  and queryDTO.icon != ''">
                and icon = #{queryDTO.icon}
            </if>
            <if test="queryDTO.catelogId != null ">
                and catelog_id = #{queryDTO.catelogId}
            </if>
        </where>
        order by sort asc, attr_group_id asc
    </select>
</mapper>