<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.org.starpivot.mall.wms.mapper.WmsPurchaseDetailMapper">

    <resultMap type="cn.org.starpivot.mall.wms.entity.WmsPurchaseDetail" id="WmsPurchaseDetailResult">
        <result property="id" column="id"/>
        <result property="purchaseId" column="purchase_id"/>
        <result property="skuId" column="sku_id"/>
        <result property="skuNum" column="sku_num"/>
        <result property="skuPrice" column="sku_price"/>
        <result property="wareId" column="ware_id"/>
        <result property="status" column="status"/>
    </resultMap>

    <sql id="selectPurchaseDetailVo">
        select id, purchase_id, sku_id, sku_num, sku_price, ware_id, status
        from wms_purchase_detail
    </sql>

    <select id="selectPageList" resultMap="WmsPurchaseDetailResult">
        <include refid="selectPurchaseDetailVo"/>
        <where>
            <if test="query.status != null">
                and status = #{query.status}
            </if>
            <if test="query.skuId != null">
                and sku_id = #{query.skuId}
            </if>
            <if test="query.purchaseId != null">
                and purchase_id = #{query.purchaseId}
            </if>
            <if test="query.onlyDemand != null and query.onlyDemand">
                and (purchase_id is null or status = 0)
            </if>
        </where>
        order by id desc
    </select>

    <select id="listByPurchaseId" resultMap="WmsPurchaseDetailResult">
        <include refid="selectPurchaseDetailVo"/>
        where purchase_id = #{purchaseId}
        order by id
    </select>
</mapper>
